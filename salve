            }

            .image-grid {
                grid-template-columns: 1fr;
            }

            .grid-item {
                height: 40vh;
            }
        }


        /* Altura do wrapper define a "duração" do efeito de scroll. 
   400vh = 4 vezes a altura da tela. Aumente se tiver mais imagens. */
        .hz-scroll-wrapper {
            height: 400vh;
            position: relative;
            background-color: #ffffff;
            font-family: sans-serif;
        }

        /* Trava na tela ocupando 100% do espaço */
        .hz-sticky-container {
            position: sticky;
            top: 0;
            height: 100vh;
            width: 100%;
            overflow: hidden;
            display: flex;
            align-items: center;
            color: #111;
        }

        /* --- Elementos Flutuantes da UI --- */
        .hz-header,
        .hz-footer {
            position: absolute;
            left: 0;
            width: 100%;
            padding: 0 40px;
            display: flex;
            justify-content: space-between;
            z-index: 10;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .hz-header {
            top: 30px;
        }

        .hz-footer {
            bottom: 30px;
        }

        .hz-logo {
            font-size: 1.5rem;
            letter-spacing: -2px;
            line-height: 0.8;
        }

        .hz-links span {
            margin-left: 20px;
            cursor: pointer;
        }

        .hz-floating-text {
            position: absolute;
            right: 25%;
            top: 25%;
            z-index: 10;
            font-size: 0.85rem;
        }

        /* --- O Carrossel --- */
        .hz-carousel-track {
            display: flex;
            align-items: center;
            gap: 8vw;
            /* Espaço entre as imagens */
            height: 70vh;
            padding: 0 35vw;
            /* Empurra o 1º item pro centro */
            will-change: transform;
        }

        .hz-carousel-item {
            flex-shrink: 0;
            width: 30vw;
            /* Largura da imagem central */
            height: 100%;
            will-change: transform;
        }

        .hz-carousel-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(20%);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        /* Responsividade Básica */
        @media (max-width: 768px) {
            .hz-carousel-track {
                padding: 0 20vw;
            }

            .hz-carousel-item {
                width: 60vw;
            }

            .hz-links {
                display: none;
            }

            .hz-floating-text {
                right: 5%;
            }
        }



        /* Container principal do Grid */
        .shutter-grid {
            display: flex;
            gap: 15px;
            /* Espaçamento entre os painéis */
            width: 100%;
            max-width: 1200px;
            height: 450px;
            margin: 0 auto;
            background-color: #1a1a1a;
            /* Fundo escuro como na imagem */
            padding: 20px;
        }

        /* Cada painel individual */
        .panel {
            position: relative;
            flex: 1;
            overflow: hidden;
            /* Garante que a imagem tremendo não saia da caixa */
            background-color: #000;
        }

        /* Ícone de estrela centralizado */
        .star-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 40px;
            font-family: sans-serif;
            z-index: 10;
            pointer-events: none;
            /* Ignora cliques na estrela */
        }

        /* Camada da imagem com a animação */
        .image-layer {
            position: absolute;
            /* Deixa a imagem maior que o painel para não mostrar bordas vazias ao tremer */
            top: -10%;
            left: -10%;
            width: 120%;
            height: 120%;
            background-size: cover;
            background-position: center;
            filter: grayscale(100%);
            /* Aplica o tom preto e branco da sua referência */
        }

        /* * Animações individuais com tempos diferentes 
   * para que as imagens não tremam todas em sincronia 
   */
        .panel:nth-child(1) .image-layer {
            animation: shutterEffect 0.3s infinite alternate;
        }

        .panel:nth-child(2) .image-layer {
            animation: shutterEffect 0.25s infinite alternate-reverse;
        }

        .panel:nth-child(3) .image-layer {
            animation: shutterEffect 0.35s infinite alternate;
            animation-delay: 0.1s;
        }

        .panel:nth-child(4) .image-layer {
            animation: shutterEffect 0.28s infinite alternate-reverse;
            animation-delay: 0.2s;
        }

        .panel:nth-child(5) .image-layer {
            animation: shutterEffect 0.32s infinite alternate;
            animation-delay: 0.15s;
        }

        /* Insira os caminhos das suas imagens aqui */
        .img-1 {
            background-image: url('https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=800&q=80"');
        }

        .img-2 {
            background-image: url('https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=800&q=80"');
        }

        .img-3 {
            background-image: url('https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=800&q=80"');
        }

        .img-4 {
            background-image: url('https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=800&q=80"');
        }

        .img-5 {
            background-image: url('https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=800&q=80"');
        }

        /* * Keyframes responsáveis por simular o obturador da câmera.
   * Ele move a imagem, dá zoom e aplica o blur em frações de segundo.
   */
        @keyframes shutterEffect {
            0% {
                transform: translate(0, 0) scale(1);
                filter: grayscale(100%) blur(1px);
                opacity: 0.9;
            }

            25% {
                transform: translate(-8px, 4px) scale(1.05);
                filter: grayscale(100%) blur(6px);
                opacity: 0.7;
            }

            50% {
                transform: translate(5px, -6px) scale(1.02);
                filter: grayscale(100%) blur(2px);
                opacity: 0.8;
            }

            75% {
                transform: translate(-3px, 8px) scale(1.08);
                filter: grayscale(100%) blur(8px);
                opacity: 0.6;
            }

            100% {
                transform: translate(6px, -3px) scale(1.04);
                filter: grayscale(100%) blur(3px);
                opacity: 0.9;
            }
        }


