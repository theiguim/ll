    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: #FAFAFA;
            /* Fundo claro, sólido e minimalista */
            color: #111;
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            /* Evita rolagem horizontal */
        }

        /* --- Seção 1: Portfólio (Hero & Grid) --- */
        .portfolio-section {
            width: 100%;
            display: flex;
            flex-direction: column;
        }

        .header-section {
            padding: 8vh 5% 4vh 5%;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .title-container {
            position: relative;
            text-align: center;
            height: 180px;
            width: 100%;
            margin-bottom: 20px;
        }

        .cursive-title {
            font-family: 'Italianno', cursive;
            font-size: 9rem;
            font-weight: 400;
            position: absolute;
            top: -60px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 2;
            color: #111;
            white-space: nowrap;
        }

        .bold-title {
            font-family: 'Anton', sans-serif;
            font-size: 7rem;
            line-height: 1;
            letter-spacing: -2px;
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1;
            color: #E2E2E2;
            /* Título de trás mais claro para dar profundidade estética */
        }

        .info-bar {
            display: flex;
            justify-content: space-between;
            width: 100%;
            max-width: 1200px;
            font-weight: 600;
            font-size: 1rem;
            letter-spacing: 2px;
            color: #111;
            text-transform: uppercase;
            border-top: 1px solid #ddd;
            padding-top: 15px;
        }

        /* --- Grid de Imagens Full Width --- */
        .image-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            width: 100%;
        }

        .grid-item {
            width: 100%;
            height: 50vh;
            /* Altura responsiva baseada na tela */
            overflow: hidden;
            position: relative;
        }

        .grid-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(40%);
            transition: filter 0.5s ease, transform 0.8s ease;
        }

        /* Efeito Aesthetic no Hover */
        .grid-item:hover .grid-img {
            filter: grayscale(0%);
            transform: scale(1.03);
        }

        .contact-info {
            background-color: #111;
            color: #FAFAFA;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            font-size: 0.85rem;
            font-weight: 400;
            letter-spacing: 1px;
            line-height: 1.8;
        }

        /* --- Seção 2: Editorial / Magazine (Split Screen) --- */
        .magazine-section {
            display: flex;
            width: 100%;
            min-height: 100vh;
            background-color: #FFFFFF;
            /* margin-top: 5px; */
            /* Leve respiro entre as seções */
        }

        .image-side {
            width: 50%;
            background-image: url('https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=1200&q=80');
            background-size: cover;
            background-position: center;
        }

        .text-side {
            width: 50%;
            padding: 8% 8% 8% 5%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .main-title {
            font-family: 'Anton', sans-serif;
            font-size: 8rem;
            line-height: 0.85;
            color: #111;
            margin-bottom: 40px;
            letter-spacing: -2px;
            text-transform: uppercase;
        }

        .main-title span {
            display: block;
        }

        /* Deslocamento artístico invadindo a imagem levemente */
        .title-line1 {
            margin-left: 0;
        }

        .title-line2 {
            margin-left: -80px;
        }

        .title-line3 {
            margin-left: -120px;
        }

        .intro-text {
            font-size: 1.2rem;
            line-height: 1.6;
            color: #333;
            margin-bottom: 40px;
            font-weight: 300;
            max-width: 600px;
        }

        .intro-text strong {
            font-weight: 700;
            color: #111;
        }

        .intro-text em {
            font-style: italic;
            font-family: serif;
            color: #555;
        }

        .article-body {
            font-size: 0.95rem;
            line-height: 1.8;
            color: #444;
            max-width: 600px;
            text-align: justify;
        }

        .article-body p {
            margin-bottom: 20px;
        }

        .article-body p:first-of-type::first-letter {
            float: left;
            font-family: 'Italianno', cursive;
            font-size: 6rem;
            line-height: 0.6;
            padding-top: 15px;
            padding-right: 15px;
            color: #111;
        }

        /* --- Responsividade para Mobile --- */
        @media (max-width: 900px) {
            .image-grid {
                grid-template-columns: repeat(2, 1fr);
            }

