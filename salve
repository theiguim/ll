    /* O "steps(4)" cria o efeito de pular quadros como um GIF */
    animation: shutterEffect 0.4s infinite alternate steps(4); 
}

.glitch-star {
    position: relative;
    z-index: 2;
    color: #ffffff;
    font-size: 2.5rem;
}

/* Animação que simula o movimento brusco e o desfoque de movimento */
@keyframes shutterEffect {
    0%   { transform: translate(0px, 0px) scale(1); filter: grayscale(100%) blur(0px); }
    25%  { transform: translate(-8px, 5px) scale(1.05); filter: grayscale(100%) blur(3px); }
    50%  { transform: translate(6px, -4px) scale(1.02); filter: grayscale(100%) blur(1px); }
    75%  { transform: translate(-4px, -6px) scale(1.08); filter: grayscale(100%) blur(4px); }
    100% { transform: translate(5px, 3px) scale(1.03); filter: grayscale(100%) blur(2px); }
}

